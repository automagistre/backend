{
  "name": "backend2",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/fastify": "^3.1.0",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/uuid": "^10.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dataloader": "^2.2.3",
    "dependency-graph": "^1.0.0",
    "graphql": "^16.14.2",
    "graphql-subscriptions": "^3.0.0",
    "graphql-type-json": "^0.3.2",
    "jwks-rsa": "^3.2.2",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.5",
    "@types/passport-http-bearer": "^1.0.42",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "prettier": "^3.9.5",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.8.0",
    "prisma-nestjs-graphql": "^21.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "@apollo/server-plugin-landing-page-graphql-playground": {
      "@apollo/server": "^5.2.0"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!uuid)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/common/testing/**",
      "!main.ts",
      "!**/*.module.ts",
      "!generated/**"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/common/testing/"
    ],
    "coverageReporters": [
      "text-summary",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 9,
        "branches": 9,
        "functions": 5,
        "lines": 9
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
