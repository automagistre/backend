HARBOR_REGISTRY=harbor.example.com/project
TAG=latest

DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
AUTH_SKIP_CHECK=false
JWT_SECRET=
JWT_AUDIENCE=
JWT_ISSUER=
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400

# Keycloak
KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=

# Password auth (fallback)
PASSWORD_AUTH_ENABLED=false

# UIS webhook security (optional)
UIS_WEBHOOK_SHARED_SECRET=
UIS_WEBHOOK_SECRET_HEADER=x-uis-webhook-secret
UIS_WEBHOOK_REQUIRE_QUERY_TOKEN=true

# UIS polling reconcile (disabled by default)
UIS_POLLING_ENABLED=false
UIS_DATA_API_URL=https://dataapi.uiscom.ru/v2.0
UIS_DATA_API_ACCESS_TOKEN=
UIS_POLLING_LOOKBACK_MINUTES=180
UIS_POLLING_OVERLAP_SECONDS=120
UIS_POLLING_PAGE_LIMIT=200
UIS_POLLING_MAX_PAGES=20
UIS_POLLING_REQUEST_TIMEOUT_MS=25000
UIS_POLLING_REQUEST_RETRY_COUNT=2
UIS_POLLING_REQUEST_RETRY_DELAY_MS=1200
# UIS timezone offset in minutes, e.g. Moscow = 180
UIS_TIMEZONE_OFFSET_MINUTES=180

# UIS recordings downloader (disabled by default)
UIS_RECORDINGS_DOWNLOAD_ENABLED=false
UIS_RECORDINGS_DOWNLOAD_BATCH_LIMIT=10
UIS_RECORDINGS_DOWNLOAD_TIMEOUT_MS=30000
UIS_RECORDINGS_DOWNLOAD_RETRY_COUNT=2
UIS_RECORDINGS_DOWNLOAD_RETRY_DELAY_MS=1500
CALL_RECORDINGS_DIR=storage/call-recordings

# Calls retention / cleanup jobs (disabled by default)
CALLS_RETENTION_ENABLED=false
CALL_EVENTS_RETENTION_DAYS=120
CALL_RECORDINGS_RETENTION_DAYS=365
CALL_RECORDINGS_RETENTION_BATCH_LIMIT=200
CALL_RECORDINGS_RETENTION_DELETE_FILES=false
